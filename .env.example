APP_ENV=development
SECRET_KEY=change-me-in-production

# LLM — OpenAI
OPENAI_API_KEY=sk-...
DEFAULT_LLM_MODEL=gpt-4o-mini

# LLM — Ollama (local, Mac Mini M1)
# Set OPENAI_BASE_URL=http://localhost:11434/v1 to use Ollama instead
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379

# Observability (choose one)
LANGSMITH_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
